# Firebase Configuration
VITE_FIREBASE_API_KEY=your-firebase-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
VITE_FIREBASE_APP_ID=your-app-id
VITE_FIREBASE_MEASUREMENT_ID=your-measurement-id

# Cloudinary Configuration (solo para uploads sin firmar)
# NOTA: apiSecret NO debe estar en el frontend - usar Firebase Functions
VITE_CLOUDINARY_CLOUD_NAME=your-cloud-name
VITE_CLOUDINARY_UPLOAD_PRESET=your-upload-preset

# ============================================================
# SECRETOS - NO PONER EN EL FRONTEND
# Estos valores deben configurarse en Firebase Secret Manager:
#   - TELEGRAM_TOKEN
#   - OPENAI_API_KEY
#   - CLOUDINARY_API_KEY
#   - CLOUDINARY_API_SECRET
#
# Usar: firebase functions:secrets:set NOMBRE_DEL_SECRETO
# ============================================================
